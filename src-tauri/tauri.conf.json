{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-app-json-schema/refs/heads/main/schemas/tauri-v2.json",
  "productName": "互动影游编辑器",
  "identifier": "com.drama.editor",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "互动影游编辑器",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {}
}
